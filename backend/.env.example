# QDRANT_API_KEY is optional for local Qdrant, but required for hosted Qdrant services.
QDRANT_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJhY2Nlc3MiOiJtIiwic3ViamVjdCI6ImFwaS1rZXk6OTE4YWMxOWYtMGM0My00YzA1LThjYmMtMzNiYTNhMDk3ZTBkIn0.ZO1hIbeXmbN0E0RiFsQ9414detwv2vP5juWnHkOXaJw
# GROQ_API_KEY is required for Groq generative AI requests.
